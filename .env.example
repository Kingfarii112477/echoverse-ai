# ==============================================================
# EchoVerse AI — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ==============================================================

# ── Supabase (required) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App URL ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.echoverse.ai

# ── AI Services (server-side only — no NEXT_PUBLIC_) ─────────
ELEVENLABS_API_KEY=sk_your_elevenlabs_key
OPENAI_API_KEY=sk-your-openai-key
DEEPGRAM_API_KEY=your-deepgram-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_API_KEY=your-google-ai-studio-key

# Active provider selection (optional — auto-detected from keys)
# ACTIVE_TTS_PROVIDER=elevenlabs
# ACTIVE_LLM_PROVIDER=openai

# ── Payments (Paddle) ─────────────────────────────────────────
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your-paddle-client-token
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret

# ── Security ──────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars
SESSION_SECRET=your-session-secret-min-32-chars
WEBHOOK_SIGNING_SECRET=your-webhook-signing-secret

# ── Android Build (CI only) ───────────────────────────────────
# ANDROID_KEYSTORE_BASE64=base64-encoded-keystore-file
# ANDROID_KEY_ALIAS=echoverse-key
# ANDROID_KEY_PASSWORD=your-key-password
# ANDROID_STORE_PASSWORD=your-store-password
